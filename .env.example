# 可选：AI 功能的钥匙（narrate.js 整页讲解 + server.js 的实验页 AI 助教）
# 在 https://console.anthropic.com 申请。不填的话，其余功能全部照常。
ANTHROPIC_API_KEY=

# 可选：讲解音色（默认 en-US-AndrewMultilingualNeural；中文课推荐 zh-CN-YunxiNeural）
# NARRATE_VOICE=zh-CN-YunxiNeural

# 可选：server.js 端口（默认 3100）与 AI 助教模型
# PORT=3100
# ASSISTANT_MODEL=claude-sonnet-5
